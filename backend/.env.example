# ===== Cura — backend environment template =====
# Copy this file to `.env` (in the backend folder) and fill in the values.
# Never commit your real `.env` — it's already in .gitignore.

# ---- Core ----
# Note: avoid port 5000 on macOS — Apple's AirPlay Receiver squats on it
# (System Settings → General → AirDrop & Handoff → AirPlay Receiver).
PORT=5050
MONGODB_URI=mongodb://localhost:27017/healthcare_db
NODE_ENV=development

# ---- Auth (REQUIRED) ----
# Generate a strong secret (at least 32 chars) before running. One-liner:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# A 3-character secret like "sai" is trivially breakable — don't use one.
JWT_SECRET=replace-me-with-a-real-random-string

# ---- Google Gemini (REQUIRED for prescription reader, AI suggestions, health assistant) ----
# Get a free key from https://aistudio.google.com/
GEMINI_API_KEY=your-google-ai-studio-api-key

# Optional — override the default Gemini model
GEMINI_MODEL=gemini-2.5-flash

# ---- HeyGen LiveAvatar (OPTIONAL — only needed for the avatar feature in the Health Assistant) ----
# Sign up at https://heygen.com/ to get an API key + an avatar ID.
# The backend tries LIVEAVATAR_API_KEY first, then falls back to HEYGEN_API_KEY.
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=
HEYGEN_API_KEY=

# ---- Frontend origin (OPTIONAL — only needed if your frontend isn't on localhost:5173) ----
# FRONTEND_URL=http://localhost:5173
